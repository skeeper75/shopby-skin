[
  {
    "method": "GET",
    "path": "/coupons",
    "summary": "내 쿠폰 가져오기",
    "description": " ## 부가설명 및 특이사항\n 로그인한 사용자가 보유한 쿠폰중 사용가능한 쿠폰과 이미 사용한 쿠폰을 구분하여 조회합니다.\n\n ## 화면 예시\n <a target='_blank' href='http://image.toast.com/aaaaahb/api-description/order/coupon/[GET]%20coupons%20%EB%82%B4%20%EC%BF%A0%ED%8F%B0%20%EA%B0%80%EC%A0%B8%EC%98%A4%EA%B8%B0(%EB%A7%88%EC%9D%B4%ED%8E%98%EC%9D%B4%EC%A7%80).png'><img src='http://image.toast.com/aaaaahb/api-description/order/coupon/[GET]%20coupons%20%EB%82%B4%20%EC%BF%A0%ED%8F%B0%20%EA%B0%80%EC%A0%B8%EC%98%A4%EA%B8%B0(%EB%A7%88%EC%9D%B4%ED%8E%98%EC%9D%B4%EC%A7%80).png?autox150'></a>",
    "tags": ["Coupon"],
    "parameters": [
      {
        "name": "couponNos",
        "in": "query",
        "description": "쿠폰 번호^|[1, 2, 3]",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "desc",
        "in": "query",
        "description": "내림차순 정렬 여부^|false",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "endYmd",
        "in": "query",
        "description": "검색 종료 일 (지정 하지 않을 시 오늘 날짜까지 조회)^|yyyy-MM-dd",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "pageNumber",
        "in": "query",
        "description": "페이지 번호^|1",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "pageSize",
        "in": "query",
        "description": "한 페이지당 노출 수^|30",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "searchDateType",
        "in": "query",
        "description": "기간 검색타입 (REGISTER_YMD: 등록일(default), USE_END_YMD: 사용 종료일)^|REGISTER_YMD",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "startYmd",
        "in": "query",
        "description": "검색 시작 일 (지정 하지 않을 시 3개월 전 오늘 날짜부터 조회)^|yyyy-MM-dd",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "usable",
        "in": "query",
        "description": "사용가능 여부 (true: 사용 가능 / false: 사용 불가능 / null: 조건 없음)^|true",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "Version",
        "in": "header",
        "description": "API 버전^|1.0",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "1.0"
      },
      {
        "name": "accessToken",
        "in": "header",
        "description": "로그인 인증키^|test-access-token",
        "required": false,
        "schema": {
          "type": "string"
        },
        "example": "test-access-token"
      },
      {
        "name": "Shop-By-Authorization",
        "in": "header",
        "description": "액세스 토큰(Oauth2 스펙)^|Bearer test-access-token",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "clientId",
        "in": "header",
        "description": "쇼핑몰 클라이언트 아이디^|test-client-id",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "test-client-id"
      },
      {
        "name": "platform",
        "in": "header",
        "description": "클라이언트 플랫폼 (PC, MOBILE_WEB, AOS, IOS)^|PC",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "PC"
      },
      {
        "name": "language",
        "in": "header",
        "description": "언어 (기본 값: ko)^|PC",
        "required": false,
        "schema": {
          "type": "string"
        },
        "example": "ko"
      }
    ],
    "responses": {
      "200": {
        "description": "200",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/coupons239781785"
            },
            "examples": {
              "get-my-coupons": {
                "value": "{\"items\":[{\"couponIssueNo\":1,\"couponName\":\"쿠폰 이름!\",\"reason\":null,\"couponNo\":3,\"couponType\":\"PRODUCT\",\"couponSubType\":\"NONE\",\"discountAmt\":1,\"discountRate\":0,\"fixedAmt\":true,\"issueYmdt\":\"2025-10-23 15:45:34\",\"limitPayType\":\"NAVER_PAY\",\"limitPayTypes\":[\"NAVER_PAY\"],\"maxDiscountAmt\":0,\"maxSalePrice\":0,\"minSalePrice\":0,\"otherCouponUsable\":true,\"cartCouponUsable\":true,\"productCouponUsable\":true,\"skipsAccumulation\":true,\"usablePlatforms\":[\"PC\"],\"useEndYmdt\":\"2025-10-23 15:45:34\",\"useYmdt\":\"2025-10-23 15:45:34\",\"used\":true,\"couponTargetType\":\"CATEGORY\",\"memberGradeNames\":[\"VIP\"],\"memberGroupNames\":[\"임원\"],\"benefitAmt\":0,\"accumulationUnit\":\"\",\"freeDelivery\":false,\"minDeliveryAmt\":null,\"fiexdAmt\":true}],\"totalCount\":1}"
              }
            }
          }
        }
      }
    }
  },
