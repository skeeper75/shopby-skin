{
  "name": "@shopby/react-skin",
  "version": "1.16.5",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "build:default": "webpack --config webpack.config.js",
    "build:dev": "yarn build:default --node-env development --mode=development --env MODE=dev",
    "build:cli": "webpack --config config/webpack.cli.js",
    "build": "yarn build:default --node-env production --mode=production --env MODE=prod",
    "build:beta": "yarn build:default --node-env beta --mode=production --env MODE=prod --env RELEASE_MODE=beta",
    "release:prerelease": "yarn build RELEASE_TYPE=prerelease RELEASE_IDENTIFIER=alpha",
    "release:major": "yarn build RELEASE_TYPE=major",
    "release:minor": "yarn build RELEASE_TYPE=minor",
    "release:patch": "yarn build RELEASE_TYPE=patch",
    "start": "webpack serve --node-env development --mode=development --env MODE=dev",
    "start:beta": "webpack serve --node-env development --mode=development --env MODE=dev --env RELEASE_MODE=beta",
    "start:prod": "webpack serve --node-env production --mode=production --env MODE=prod",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "devDependencies": {
    "@babel/core": "^7.20.2",
    "@babel/eslint-parser": "^7.19.1",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-webpack5": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^9.1.0",
    "chromatic": "^15.3.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.2",
    "dayjs": "^1.11.7",
    "dompurify": "^3.0.1",
    "dotenv": "^16.0.3",
    "dotenv-webpack": "^8.0.1",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-tui": "^5.2.1",
    "eslint-plugin-html": "^7.1.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx": "^0.1.0",
    "eslint-plugin-react": "^7.31.10",
    "eslint-webpack-plugin": "^3.2.0",
    "file-loader": "^6.2.0",
    "happy-dom": "^20.8.4",
    "html-webpack-plugin": "^5.5.0",
    "html-webpack-tags-plugin": "^3.0.2",
    "husky": "^8.0.2",
    "i18next": "^22.0.6",
    "i18next-browser-languagedetector": "^7.0.1",
    "i18next-http-backend": "^2.0.1",
    "js-cookie": "^3.0.1",
    "lodash-es": "^4.17.21",
    "mini-css-extract-plugin": "^2.6.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "postcss-loader": "^7.3.4",
    "react": "^18.2.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-i18next": "^12.0.0",
    "react-router-dom": "^6.4.3",
    "storybook": "^8.6.18",
    "style-loader": "^3.3.1",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "vitest": "^3.2.4",
    "webpack": "^5.75.0",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.11.1",
    "webpack-merge": "^5.8.0",
    "whatwg-fetch": "^3.6.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@shopby/react-components": "git+https://skins.shopby.co.kr/developers/react-components.git#v1.16.5",
    "@shopby/shared": "git+https://skins.shopby.co.kr/developers/shared.git#v1.16.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.577.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^2.6.1"
  }
}
